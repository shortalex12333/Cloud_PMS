# =============================================================================
# Cloud_PMS — Local backend environment — TEMPLATE
# =============================================================================
# Copy to deploy/local/.env and fill in real values.
# NEVER commit the filled-in .env — it's in .gitignore for a reason.
# =============================================================================

# -- Runtime ------------------------------------------------------------------
ENVIRONMENT=local
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
PYTHONPATH=/app
PORT=8080

# -- Supabase: MASTER DB (auth + directory) -----------------------------------
# MASTER = qvzmkaamzaqxpzbewjxe per memory reference_cloud_pms_db.md
MASTER_SUPABASE_URL=
MASTER_SUPABASE_SERVICE_KEY=
MASTER_SUPABASE_JWT_SECRET=

# -- Supabase: TENANT DB (all PMS operational data) ---------------------------
# TENANT = vzsohavtuotocgrfkfyd per memory reference_cloud_pms_db.md
TENANT_SUPABASE_JWT_SECRET=

# -- Vessel defaults for seed / dev ------------------------------------------
DEFAULT_YACHT_CODE=

# -- Raw Postgres DSNs (used by workers and RLS probe) ------------------------
READ_DB_DSN=
DATABASE_URL=

# -- Infra --------------------------------------------------------------------
REDIS_URL=

# -- AI providers -------------------------------------------------------------
OPENAI_API_KEY=

# -- Microsoft Graph (email) --------------------------------------------------
AZURE_READ_APP_ID=
AZURE_READ_CLIENT_SECRET=
AZURE_WRITE_APP_ID=
AZURE_WRITE_CLIENT_SECRET=

# -- Email feature flags ------------------------------------------------------
EMAIL_EVIDENCE_ENABLED=false
EMAIL_FOCUS_ENABLED=false
EMAIL_LINK_ENABLED=false
EMAIL_RELATED_ENABLED=false
EMAIL_RENDER_ENABLED=false
EMAIL_SEARCH_ENABLED=false
EMAIL_SYNC_ENABLED=false
EMAIL_THREAD_ENABLED=false
EMAIL_TRANSPORT_ENABLED=false

# -- Fault lens flags ---------------------------------------------------------
FAULT_LENS_SIGNED_ACTIONS_ENABLED=false
FAULT_LENS_SUGGESTIONS_ENABLED=false
FAULT_LENS_V1_ENABLED=true

# -- Certificates flags -------------------------------------------------------
FEATURE_CERTIFICATES=true
UI_CERTIFICATES=true

# -- Worker knobs -------------------------------------------------------------
WORKER_BATCH_SIZE=10
WORKER_POLL_INTERVAL=10
WORKER_STAGING_MODE=false
MAX_CONCURRENT_GLOBAL=5
MAX_CONCURRENT_PER_WATCHER=2

# -- Rate / org throttling ----------------------------------------------------
STREAMING_ENABLED_ORGS=
ORG_BURST_CAPACITY=10
ORG_TOKENS_PER_SEC=1
