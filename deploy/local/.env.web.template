# =============================================================================
# Cloud_PMS — Local FRONTEND environment — TEMPLATE
# =============================================================================
# Copy to deploy/local/.env.web and fill in real values.
# No hard secrets here — only public keys + URLs.
# NEXT_PUBLIC_* values are baked into the Next.js client bundle at build time.
# =============================================================================

# MASTER Supabase public URL + anon key (client-side auth only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend API URL — when running docker stack locally, this is typically
# http://localhost:8080 (from the browser) or http://api:8080 (server-side).
# See docs/explanations/LOCAL_DOCKER_STACK.md for split client/server config.
NEXT_PUBLIC_API_URL=

# App URL (what the app is served at)
NEXT_PUBLIC_APP_URL=

# Yacht ID salt — any non-empty string; used for deterministic short-IDs in UI
NEXT_PUBLIC_YACHT_SALT=
