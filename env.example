# =============================================================================
# Celeste Local Stack — Environment Variables
# Copy this to .env and fill in real values. Never commit .env.
# =============================================================================

# ---------------------------------------------------------------------------
# Database — Direct connection (port 5432, SSL required)
# Used by: api, cache-listener
# ---------------------------------------------------------------------------
READ_DB_DSN=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# ---------------------------------------------------------------------------
# Database — Supavisor transaction pooler (port 6543)
# Used by: projection-worker, embedding-worker, nightly-feedback-loop
# LAW 14: statement_cache_size=0 handled in app code — do not add here
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://default:PASSWORD@host:PORT

# ---------------------------------------------------------------------------
# OpenAI (embedding-worker)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Supabase — Tenant yTEST_YACHT_001
# ---------------------------------------------------------------------------
yTEST_YACHT_001_SUPABASE_SERVICE_KEY=eyJ...

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
MASTER_SUPABASE_JWT_SECRET=your-jwt-secret

# ---------------------------------------------------------------------------
# Email Watcher — Supabase (uses tenant DB, not master)
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_KEY=eyJ...

# ---------------------------------------------------------------------------
# Email Watcher — Microsoft OAuth (Azure AD app registration)
# ---------------------------------------------------------------------------
MICROSOFT_CLIENT_ID_READ=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_SECRET_READ=your-client-secret
