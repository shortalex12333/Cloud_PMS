# =============================================================================
# Docker Build Context Exclusions
# =============================================================================
# Keep build context small and fast; exclude dev/test artifacts
# =============================================================================

# Git
.git
.gitignore

# Python artifacts
__pycache__
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# NOTE: `lib/` and `lib64/` removed 2026-04-23 — they came from the standard
# Python .gitignore template and were meant to exclude venv directories. We
# build the venv at `/opt/venv` inside the Dockerfile, so those patterns
# never match anything REAL, but they DO silently exclude our source module
# `apps/api/lib/` (user_resolver + future helpers). Leaving them in made the
# entity lens routes 404 in production because `from lib.user_resolver import`
# raised ModuleNotFoundError and the try/except in pipeline_service.py:485-491
# swallowed it.
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv
venv/
ENV/
env/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
tests/
*_test.py
test_*.py
conftest.py

# Documentation (not needed in runtime)
*.md
docs/
README*
CHANGELOG*
LICENSE*

# CI/CD configs (not needed in runtime)
.github/
.gitlab-ci.yml
.travis.yml
Makefile
docker-compose*.yml

# Local env files (NEVER include secrets)
.env
.env.*
*.local
secrets/
credentials/

# Logs and temp files
*.log
logs/
tmp/
temp/

# Scripts (dev-only)
scripts/

# Handover / planning docs
handover/
*.handover.md

# Backup files
*.bak
*.backup

# Large binary artifacts
*.zip
*.tar
*.tar.gz
*.rar
